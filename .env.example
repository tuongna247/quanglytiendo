# Sao chép file này thành .env và điền giá trị thật

# Mật khẩu SA cho SQL Server (tối thiểu 8 ký tự, có hoa/thường/số/đặc biệt)
DB_SA_PASSWORD=YourStrongPassword123!

# JWT secret key — chạy: openssl rand -base64 48
JWT_KEY=Change_This_To_A_Long_Random_Secret_Key_In_Production_2024!

# Port web expose ra ngoài (nginx proxy tới cổng này)
WEB_PORT=3010

# Origin đầy đủ của web (để API cấu hình CORS đúng)
WEB_ORIGIN=https://yourdomain.com

# SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# URL frontend (dùng trong link reset password)
APP_URL=https://yourdomain.com

# URL API (dùng bởi Vite frontend khi dev)
VITE_API_URL=http://localhost:5015
